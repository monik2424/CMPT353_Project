# Copy this file to .env and fill in values before running

# Next.js
NODE_ENV=development

# MySQL connection (must match docker-compose.yml)
DB_HOST=mysql
DB_USER=root
DB_PASSWORD=rootpassword
DB_NAME=qa_db

# JWT secret for auth (change this to a long random string in production)
JWT_SECRET=change_this_to_a_long_random_secret

# Admin seed credentials (used by the seed script)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
